default_platform(:ios)

platform :ios do

  desc "Build only - no Apple API key needed (match readonly + archive)"
  lane :build_only do
    create_keychain(
      name: "build.keychain",
      password: "glamora123",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # readonly: true downloads certs from git repo without calling Apple API
    # This completely avoids app_store_connect_api_key and the OpenSSL EC key bug
    match(
      type: "appstore",
      app_identifier: "com.glamora.salon",
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: Base64.strict_encode64("#{ENV['GITHUB_ACTOR']}:#{ENV['MATCH_GIT_TOKEN']}"),
      readonly: true,
      keychain_name: "build.keychain",
      keychain_password: "glamora123"
    )

    # Archive only — xcodebuild will handle the export + upload step
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      archive_path: "/tmp/App.xcarchive",
      skip_package_ipa: true,
      skip_package_pkg: true
    )
  end

  desc "Build and upload to TestFlight (local use with working OpenSSL)"
  lane :beta do
    # Support both key file path (local) and base64-encoded key content (CI)
    if ENV["ASC_KEY_BASE64"] && !ENV["ASC_KEY_BASE64"].empty?
      key_file = "/tmp/asc_key_#{ENV['ASC_KEY_ID']}.p8"
      File.write(key_file, Base64.decode64(ENV["ASC_KEY_BASE64"]))
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: key_file,
        duration: 1200,
        in_house: false
      )
    else
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: ENV["ASC_KEY_PATH"],
        duration: 1200,
        in_house: false
      )
    end

    create_keychain(
      name: "build.keychain",
      password: "glamora123",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    match(
      type: "appstore",
      app_identifier: "com.glamora.salon",
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: Base64.strict_encode64("#{ENV['GITHUB_ACTOR']}:#{ENV['MATCH_GIT_TOKEN']}"),
      readonly: false,
      force: true,
      api_key: api_key,
      keychain_name: "build.keychain",
      keychain_password: "glamora123"
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "RTYG6CS9G2",
        provisioningProfiles: {
          "com.glamora.salon" => "match AppStore com.glamora.salon"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

end
